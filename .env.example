# Copy this file to `.env` and fill in your values.

# SEC EDGAR requires a User-Agent header on every request, formatted like:
#   "Your Name your_email@example.com"
# Requests without it (or with the default placeholder below) will be blocked.
SEC_USER_AGENT="Your Name your_email@example.com"

# Anthropic API key for generation (Stage 6).
ANTHROPIC_API_KEY="sk-ant-..."
